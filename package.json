{
  "name": "lol-ai-coach",
  "version": "1.0.0",
  "description": "Forge — LoL AI Coach (Draft + Post-game)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.forge.lolcoach",
    "productName": "Forge LoL Coach",
    "directories": { "output": "dist" },
    "files": ["index.html", "main.js", "assets/**"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
