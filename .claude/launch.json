{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["main.py"],
      "cwd": "${workspaceFolder}/backend",
      "port": 8000
    },
    {
      "name": "Frontend (Vite / React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "port": 5173
    }
  ]
}
